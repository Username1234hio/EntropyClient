{
  "name": "kloak-desktop-app",
  "version": "1.2.0",
  "description": "Entropy Client - Unofficial desktop wrapper for kloak.app",
  "main": "main.js",
  "author": {
    "name": "Username1234hio",
    "email": "aadsin10@gmail.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish always",
    "dist:win": "electron-builder --win --publish always",
    "dist:mac": "electron-builder --mac --publish always",
    "dist:linux": "electron-builder --linux --publish always"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.entropy.client",
    "productName": "Entropy Client",
    "files": [
      "main.js",
      "preload.js",
      "overlay.html",
      "splash.png",
      "icon.ico",
      "icon.png",
      "build/**",
      "node_modules/**",
      "addons/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.social-networking",
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Network",
      "maintainer": "Username1234hio <aadsin10@gmail.com>"
    },
    "publish": {
      "provider": "github",
      "owner": "Username1234hio",
      "repo": "KloakDesktopAppBeta-Unoffical-",
      "releaseType": "release"
    },
    "extraResources": [
      {
        "from": "addons",
        "to": "addons",
        "filter": [
          "**/*.js"
        ]
      }
    ]
  }
}